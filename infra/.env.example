# Backend environment variables
PORT=3001
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster-url>/masterthpt?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
AI_API_BASE_URL=

# Frontend environment variables
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://<private-or-public-backend-host>:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
