generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Student {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String?
  email             String   @unique
  password_hash     String?
  google_sub        String?
  grade             Int?
  school            String?
  learning_goal     String?
  profile_completed Boolean  @default(false)
  is_first_login    Boolean  @default(true)
  created_at        DateTime @default(now())

  @@map("students")
}

model Exam {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  subject          String
  grade            Int
  exam_type        String
  year             Int
  source           String
  generated        Boolean  @default(false)
  questions     String[]
  total_questions  Int
  duration         Int
  metadata         Json?
  created_at       String?

  @@map("exams")
}

model Question {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  question_index Int
  type           String
  content        String
  content_latex  String?
  options        String[]
  statements     String[]
  correct_answer String?
  has_image      Boolean  @default(false)
  image_url      String?
  discrimination_a   Float?
  difficulty_b   Float?
  topic_tags     String[]
  max_score      Float?

  @@map("questions")
}

model Practice {
  mongo_id   String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String   @unique
  exam_ids   String[]

  @@map("practices")
}

model History {
  mongo_id   String   @id @default(auto()) @map("_id") @db.ObjectId
  intent     String
  user_id    String
  exam_id    String
  student_ans Json
  correct_count Int     @default(0)
  score      Float?
  created_at DateTime @default(now())

  @@map("histories")
}

model LearnerProfile {
  mongo_id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  student_id               String   @unique
  theta                    Float    @default(0)
  total_attempts           Int      @default(0)
  total_correct            Int      @default(0)
  topic_mastery            Json?
  topic_attempts           Json?
  topic_correct            Json?
  recent_question_ids      String[]
  recent_topics            String[]
  last_updated_question_id String?

  @@map("learner_profiles")
}
